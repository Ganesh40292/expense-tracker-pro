# ═══════════════════════════════════════════════════════════
# ExpenseTracker Docker Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════

# ── MySQL Database ──
MYSQL_ROOT_PASSWORD=your-strong-root-password
MYSQL_DATABASE=expense_tracker
DB_USERNAME=root
DB_PASSWORD=your-strong-root-password

# ── Spring Boot ──
SPRING_PROFILES_ACTIVE=prod
JWT_SECRET=YourSuperSecretKeyThatMustBeAtLeast32BytesLong!!
SHOW_SQL=false

# ── Email (Gmail SMTP) ──
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password

# ── Frontend URL (for CORS & email links) ──
FRONTEND_URL=http://localhost

# ── Ports ──
FRONTEND_PORT=80
BACKEND_PORT=8080
MYSQL_PORT=3306
