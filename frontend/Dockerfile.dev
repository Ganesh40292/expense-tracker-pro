# ═══════════════════════════════════════════════════════════
#  ExpenseTracker Frontend — Development Dockerfile
#  Runs Vite dev server with HMR
# ═══════════════════════════════════════════════════════════

FROM node:22-alpine

WORKDIR /app

# Install dependencies
COPY package.json package-lock.json ./
RUN npm ci

# Copy source (will be overridden by bind mount in dev compose)
COPY . .

EXPOSE 5173

# Run Vite dev server, bind to 0.0.0.0 for Docker access
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
